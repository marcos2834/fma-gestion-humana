{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    { "source": "/mi-perfil-laboral", "destination": "/perfil" },
    { "source": "/mi-perfil-laboral/", "destination": "/perfil" },
    { "source": "/informe/:id", "destination": "/api/informe/:id" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0" }
      ]
    }
  ],
  "functions": {
    "api/mercadopago-webhook-perfil.js": { "maxDuration": 60 },
    "api/create-perfil-payment.js": { "maxDuration": 10 },
    "api/informe/[id].js": { "maxDuration": 10 }
  },
  "cleanUrls": true,
  "trailingSlash": false
}
